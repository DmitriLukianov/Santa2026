# ===== ПРИЛОЖЕНИЕ =====
APP_PORT=8080
APP_ENV=local
LOG_LEVEL=info
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173

# ===== CORS =====
# В продакшене замените на конкретные домены: https://myapp.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== БАЗА ДАННЫХ =====
DATABASE_URL=postgres://user:password@localhost:5432/secret_santa?sslmode=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# ===== JWT =====
JWT_SECRET=your-very-secret-key-at-least-32-characters-long
JWT_TTL=24h

# ===== SMTP (опционально) =====
SMTP_HOST=smtp.mail.ru
SMTP_PORT=587
SMTP_USERNAME=your@mail.ru
SMTP_PASSWORD=your-smtp-password
FROM_EMAIL=your@mail.ru

# ===== OAUTH =====
OAUTH_PROVIDER=github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URL=http://localhost:8080/api/v1/auth/callback

# ===== ЗАГРУЗКА ФАЙЛОВ =====
UPLOAD_DIR=./uploads

# ===== ЛИМИТЫ =====
MAX_REQUEST_BODY_SIZE=1048576
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
RATE_LIMIT_OTP_PER_HOUR=5
